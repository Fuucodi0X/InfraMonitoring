# Database credentials
ORACLE_SYS_PASSWORD=change_me
ORACLE_MONITOR_USER=monitor
ORACLE_MONITOR_PASSWORD=change_me
MYSQL_ROOT_PASSWORD=change_me
MYSQL_MONITOR_USER=monitor
MYSQL_MONITOR_PASSWORD=change_me

# Grafana
GRAFANA_ADMIN_PASSWORD=change_me
MYSQL_GRAFANA_USER=monitor
MYSQL_GRAFANA_PASSWORD=change_me

# DB Ops Exporter
ORACLE_DSN=oracle-db:1521/FREEPDB1
MYSQL_HOST=mysql-db
MYSQL_PORT=3306
DB_OPS_EXPORTER_PORT=9187
DB_OPS_POLL_INTERVAL_SECONDS=60
DB_OPS_ENABLE_ORACLE=true
DB_OPS_ENABLE_MYSQL=true
DB_OPS_ENVIRONMENT=pilot
DB_OPS_TEAM=dba
DB_OPS_OWNER=dba-team
DB_BACKUP_CRITICAL_SECONDS=86400

# Alert routing endpoints (replace for real integration)
PAGER_WEBHOOK_URL=http://alert-webhook:8080/pager
TEAM_CHAT_WEBHOOK_URL=http://alert-webhook:8080/team-chat
