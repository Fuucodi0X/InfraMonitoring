    {
      "datasource": { "type": "datasource", "uid": "-- Mixed --" },
      "description": "Users table for the selected DB. The panel runs both queries, but only the matching DB returns rows.",
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto", "cellOptions": { "type": "auto" }, "filterable": true, "inspect": true },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": []
      },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 33 },
      "id": 11,
      "options": {
        "cellHeight": "sm",
        "footer": { "countRows": true, "fields": "", "reducer": ["count"], "show": true },
        "showHeader": true
      },
      "pluginVersion": "10.0.0",
      "transformations": [
        { "id": "merge", "options": {} }
      ],
      "targets": [
        {
          "datasource": { "type": "mysql", "uid": "mysql-datasource" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT \n  CONCAT(User, '@', Host) AS User,\n  CASE \n    WHEN account_locked = 'Y' THEN 'Locked'\n    WHEN password_expired = 'Y' THEN 'Expired'\n    ELSE 'Open'\n  END AS Status,\n  COALESCE(password_last_changed, 'Never') AS Last_Password_Change,\n  CASE \n    WHEN '${db}' <> 'mysql' THEN NULL\n    WHEN password_lifetime IS NOT NULL AND password_last_changed IS NOT NULL THEN DATE_ADD(password_last_changed, INTERVAL password_lifetime DAY)\n    WHEN password_lifetime IS NULL AND (SELECT @@default_password_lifetime) > 0 AND password_last_changed IS NOT NULL THEN DATE_ADD(password_last_changed, INTERVAL (SELECT @@default_password_lifetime) DAY)\n    ELSE NULL\n  END AS Expire_Date,\n  CASE \n    WHEN '${db}' <> 'mysql' THEN NULL\n    WHEN password_lifetime IS NOT NULL AND password_last_changed IS NOT NULL THEN GREATEST(0, password_lifetime - DATEDIFF(NOW(), password_last_changed))\n    WHEN password_lifetime IS NULL AND (SELECT @@default_password_lifetime) > 0 AND password_last_changed IS NOT NULL THEN GREATEST(0, (SELECT @@default_password_lifetime) - DATEDIFF(NOW(), password_last_changed))\n    ELSE NULL\n  END AS Days_Until_Expiry\nFROM mysql.user\nWHERE '${db}' = 'mysql'\nORDER BY User;",
          "refId": "mysql"
